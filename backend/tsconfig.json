{
  "compilerOptions": {
    // Thay vì node10, dùng 'node' hoặc 'bundler' để tránh cảnh báo
    "module": "commonjs",
    "moduleResolution": "node",
    
    // Thay thế 'baseUrl' bằng 'paths' trực tiếp
    "baseUrl": "./", 
    "paths": {
      "@/*": ["src/*"]
    },
    
    // Thêm dòng này để tắt cảnh báo nếu bạn muốn giữ cấu hình cũ thêm một thời gian
    "ignoreDeprecations": "5.0",

    "target": "ES2021",
    "outDir": "./dist",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true
  }
}