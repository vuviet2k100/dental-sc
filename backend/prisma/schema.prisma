generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  }

enum Role {
  ADMIN
  DOCTOR
  STAFF
  PATIENT
}

enum AppointmentStatus {
  WAITING
  IN_PROGRESS
  DONE
  CANCELLED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?   @unique
  password  String
  role      Role     @default(PATIENT) 
  createdAt DateTime @default(now())

  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  staffAppointments Appointment[] @relation("StaffAppointments")

  @@map("Users")
}

model Patient {
  id        Int       @id @default(autoincrement()) // Đổi về Int tự động tăng cho đồng bộ hệ thống
  name      String
  phone     String    @unique
  gender    String?
  birthDate DateTime?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Đã thêm quan hệ hai chiều vào đây:
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
}

model Appointment {
  id              Int               @id @default(autoincrement())
  appointmentTime DateTime
  note            String?
  status          AppointmentStatus
  createdAt       DateTime          @default(now())

  patientId Int
  doctorId  Int
  staffId   Int? // Thêm trường staffId để liên kết với nhân viên nếu cần
  
  patient Patient @relation(fields: [patientId], references: [id])
  doctor  User    @relation(fields: [doctorId], references: [id])
  staff   User?    @relation("StaffAppointments", fields: [staffId], references: [id])
}

model MedicalRecord {
  id        Int      @id @default(autoincrement())
  diagnosis String
  treatment String
  note      String?
  createdAt DateTime @default(now())

  patientId Int
  doctorId  Int

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  User    @relation(fields: [doctorId], references: [id])

  images TreatmentImage[]
}

model TreatmentImage {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  createdAt DateTime @default(now())

  medicalRecordId Int

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id])
}
