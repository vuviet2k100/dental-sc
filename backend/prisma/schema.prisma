generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DOCTOR
  STAFF
  PATIENT
}

enum AppointmentStatus {
  WAITING
  IN_PROGRESS
  DONE
  CANCELLED
}

// Bổ sung Enum Gender
enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  password  String
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())

  appointments      Appointment[]
  medicalRecords    MedicalRecord[]
  staffAppointments Appointment[]   @relation("StaffAppointments")

  @@map("Users")
}

model Patient {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String    @unique
  gender    Gender?   // Sử dụng Enum Gender
  birthDate DateTime?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  appointments   Appointment[]
  medicalRecords MedicalRecord[]
}

model Appointment {
  id              Int               @id @default(autoincrement())
  appointmentTime DateTime
  note            String?
  status          AppointmentStatus @default(WAITING)
  createdAt       DateTime          @default(now())

  patientId Int
  doctorId  Int
  staffId   Int?

  patient       Patient        @relation(fields: [patientId], references: [id])
  doctor        User           @relation(fields: [doctorId], references: [id])
  staff         User?          @relation("StaffAppointments", fields: [staffId], references: [id])
  medicalRecord MedicalRecord? // Quan hệ 1-1 với MedicalRecord

  @@map("Appointments")
}

model MedicalRecord {
  id        Int      @id @default(autoincrement())
  diagnosis String
  treatment String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientId     Int
  doctorId      Int
  appointmentId Int @unique // Ràng buộc 1-1 với Appointment

  patient     Patient        @relation(fields: [patientId], references: [id])
  doctor      User           @relation(fields: [doctorId], references: [id])
  appointment Appointment    @relation(fields: [appointmentId], references: [id])
  images      TreatmentImage[]
}

model TreatmentImage {
  id              Int           @id @default(autoincrement())
  url             String
  createdAt       DateTime      @default(now())
  medicalRecordId Int
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
}